{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "hazpenztar",
  "version": "0.1.0",
  "identifier": "com.deme.hazpenztar",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Társasház Óvoda utca 6/a házpénztár",
        "width": 1200,
        "height": 860,
        "minWidth": 1000,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [
      "../src/initial_state_v3.json"
    ]
  }
}